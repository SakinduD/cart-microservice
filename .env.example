# ─────────────────────────────────────────────────────────────────────────────
# .env.example – Template for environment variables
#
# Copy this to .env and fill in real values.
#   cp .env.example .env
#
# NEVER commit the real .env file (it is in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# Port the service listens on (default 8002)
PORT=8002

# MongoDB Atlas connection string (replace <user>, <password>, <cluster>)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cartDB?retryWrites=true&w=majority

# Base URL of the Product microservice (teammate's Azure service)
PRODUCT_SERVICE_URL=https://product-service-groupmate.azurecontainerapps.io
